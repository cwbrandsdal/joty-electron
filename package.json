{
  "name": "joty-electron",
  "version": "1.2.0",
  "description": "Joty — Notes that keep up (Desktop)",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:39173 && electron .\"",
    "build": "tsc -b && vite build",
    "package": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "release:win": "npm run build && electron-builder --win nsis --publish always",
    "start": "electron .",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{cjs,mjs,css,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@workos-inc/authkit-react": "^0.16.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.9.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "io.joty.desktop",
    "productName": "Joty",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Joty-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cwbrandsdal",
        "repo": "joty-electron",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Joty"
    }
  }
}
